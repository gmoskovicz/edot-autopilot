# .otel/contracts.yaml — Telemetry coverage contracts for this service.
#
# Generated by EDOT Autopilot after Phase 3 (Business Span Enrichment).
# Treat this file like a test suite: it fails CI when a required span attribute
# disappears from source code, and warns when contracted files change without
# updating spans.
#
# Validate:       python otel-contracts.py validate
# Drift check:    python otel-contracts.py drift --base origin/main
# Full report:    python otel-contracts.py report
#
# Install pre-push hook (optional):
#   cp .githooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

version: "1"
service: "my-ecommerce-service"          # must match OTEL_SERVICE_NAME
generated_by: "edot-autopilot"
generated_at: "2026-01-01T00:00:00Z"    # updated each time the agent re-runs

contracts:

  # ── Tier A: auto-instrumented span enriched by developer ─────────────────
  # The framework creates the span; developer calls get_current_span() to enrich it.
  # Set auto_instrumented: true so the validator skips the span-name presence check.
  - id: create-order
    description: "Customer places an order"
    span_name: "POST /orders"
    auto_instrumented: true
    source_files:
      - path: api/checkout.py
        language: python                 # python | nodejs | java | go | ruby | php | dotnet
    required_attributes:
      - order.id
      - order.value_usd
      - order.item_count
      - customer.tier
      - payment.method
      - fraud.score
      - fraud.decision
    forbidden_attributes:               # validator flags these as PII violations
      - customer.email
      - customer.name
      - customer.phone
      - customer.ip_address

  # ── Tier B: manually created span ────────────────────────────────────────
  - id: payment-authorize
    description: "Payment authorization"
    span_name: "payment.authorize"
    auto_instrumented: false
    source_files:
      - path: payments/processor.py
        language: python
    required_attributes:
      - payment.provider
      - payment.amount
      - payment.currency
      - payment.customer_id
    forbidden_attributes:
      - payment.card_number
      - payment.cvv

  # ── Tier C: monkey-patched third-party library ────────────────────────────
  - id: stripe-charge
    description: "Stripe charge creation"
    span_name: "stripe.charge.create"
    auto_instrumented: false
    source_files:
      - path: instrumentation/stripe_patch.py
        language: python
    required_attributes:
      - payment.provider
      - payment.amount
      - payment.currency
      - payment.charge_id
      - payment.status

  # ── Tier D: Bash script emitting via HTTP sidecar ─────────────────────────
  # The validator searches the script for the attribute key strings in the
  # JSON POST body (e.g., "size_mb": ...).
  - id: nightly-backup
    description: "Nightly database backup"
    span_name: "backup.complete"
    auto_instrumented: false
    source_files:
      - path: scripts/backup.sh
        language: bash
    required_attributes:
      - size_mb
      - duration_s
      - status
