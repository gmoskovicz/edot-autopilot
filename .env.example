# ── Elastic Observability (OTLP) ─────────────────────────────────────────────
# Your OTLP ingest endpoint (from Elastic Cloud → Integrations → APM)
ELASTIC_OTLP_ENDPOINT=https://<deployment>.ingest.<region>.gcp.elastic.cloud:443

# API key with APM write access
ELASTIC_API_KEY=<base64-encoded-id:key>

# ── OpenTelemetry standard env vars (auto-used by EDOT SDKs) ─────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=${ELASTIC_OTLP_ENDPOINT}
OTEL_EXPORTER_OTLP_HEADERS=Authorization=ApiKey ${ELASTIC_API_KEY}
OTEL_DEPLOYMENT_ENVIRONMENT=production

# ── Per-service (override in each test project) ───────────────────────────────
OTEL_SERVICE_NAME=edot-test-service
SERVICE_VERSION=1.0.0

# ── Sidecar (Tier D) ──────────────────────────────────────────────────────────
SIDECAR_PORT=9411
