# EDOT Autopilot — Environment Variables Template
# Copy to .env.otel and fill in your values. Never commit the filled file.

# ── Required ──────────────────────────────────────────────────────────────────
# Elastic Cloud OTLP ingest endpoint (no trailing slash)
ELASTIC_OTLP_ENDPOINT=https://<deployment>.apm.<region>.cloud.es.io

# API key with APM write access (Stack Management → API Keys → Create)
ELASTIC_API_KEY=<base64-encoded-id:key>

# Service name — used as the primary label in Kibana APM
OTEL_SERVICE_NAME=my-service

# ── Optional ──────────────────────────────────────────────────────────────────
# Deployment environment label (production / staging / development)
OTEL_DEPLOYMENT_ENVIRONMENT=production

# Service version — auto-detected from git if omitted
# SERVICE_VERSION=1.0.0

# Sampling rate (1.0 = 100% of traces, reduce for high-volume services)
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Sidecar port (Tier D only)
SIDECAR_PORT=9411

# Legacy service name (used when docker-compose-sidecar.yml starts the sidecar)
LEGACY_SERVICE_NAME=my-legacy-service

# ── Auto-set (do not edit — these are derived from the values above) ──────────
# Set these if your framework reads standard OTel env vars instead of the
# ELASTIC_* vars above:
#
# OTEL_EXPORTER_OTLP_ENDPOINT=$ELASTIC_OTLP_ENDPOINT
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=ApiKey $ELASTIC_API_KEY
# OTEL_METRICS_EXPORTER=otlp
# OTEL_LOGS_EXPORTER=otlp
# OTEL_RESOURCE_ATTRIBUTES=service.version=1.0.0,deployment.environment=production
